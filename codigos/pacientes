    "Acute respiratory failure with hypoxia",
    "Acute respiratory failure, unspecified whether with hypoxia or hypercapnia",
    "Bronchiectasis without acute exacerbation",
    "Other pulmonary insufficiency, not elsewhere classified",
    "Pulmonary eosinophilia",
    "Respiratory failure, unspecified with hypercapnia",
    "Respiratory failure, unspecified with hypoxia",
    "Respiratory failure, unspecified, unspecified whether with hypoxia or hypercapnia",
    "Septic pulmonary embolism"
]

final_df["diagnostico_entrada"] = None

final_df.loc[
    final_df["seq2_long_title"].isin(grupo_1),
    "diagnostico_entrada"
] = "sepse_pneumonia"

final_df.loc[
    final_df["seq2_long_title"].isin(grupo_2),
    "diagnostico_entrada"
] = "sepse_resp_failure"

final_df = final_df[final_df["diagnostico_entrada"].notna()].copy()
final_df = final_df[["hadm_id", "diagnostico_entrada"]].copy()

# =========================
# 9) SALVAR CSV
# =========================
output_file = desktop / "entubados_seq1_sepse_seq2_respiratorio2.csv"
final_df.to_csv(output_file, index=False)

print(f"CSV salvo em: {output_file}")
print(final_df.head())
print(len(final_df))

